# ===============================
# ADMIN CREDENTIALS
# ===============================
ADMIN_EMAIL=admin123@gmail.com
ADMIN_PASSWORD=admin123@

# ===============================
# DATABASE CREDENTIALS
# ===============================
# Default works with H2 in-memory DB (zero config)
DB_USERNAME=sa
DB_PASSWORD=

# ===============================
# JWT SECRET
# ===============================
JWT_SECRET=your-jwt-secret

# ===============================
# SENDGRID API KEY
# ===============================
SENDGRID_API_KEY=your-sendgrid-key

# ===============================
# SMTP / Gmail
# ===============================
SMTP_USERNAME=your-gmail@example.com
SMTP_PASSWORD=your-gmail-password

# ===============================
# NOTES
# ===============================
# 1. Copy this file to create your local .env:
#    cp .env.example .env
# 2. Fill your real secrets in the copied .env for production use
# 3. Keep your real .env file ignored in .gitignore
